# Environment variables for BOLDR Intelligence Engine
# Copy this to .env and fill in your values

# LLM API Keys
GLM_API_KEY=your_glm_api_key_here
OPENAI_API_KEY=your_openai_api_key_here  # Fallback model
ANTHROPIC_API_KEY=your_anthropic_api_key_here  # Claude fallback for edge cases

# n8n Configuration
N8N_HOST=0.0.0.0
N8N_PORT=5678
N8N_PROTOCOL=http
GENERIC_TIMEZONE=Asia/Singapore

# ChromaDB Configuration
CHROMA_HOST=chromadb
CHROMA_PORT=8000
CHROMA_PERSIST_DIR=/chroma/chroma

# Gmail Integration (for email channel)
GMAIL_CLIENT_ID=your_gmail_client_id
GMAIL_CLIENT_SECRET=your_gmail_client_secret
GMAIL_REFRESH_TOKEN=your_gmail_refresh_token

# Streamlit Dashboard
STREAMLIT_PORT=8501
STREAMLIT_SERVER_HEADLESS=true

# App Configuration
KB_DATA_DIR=/app/kb
DATA_DIR=/app/data
CONFIDENCE_THRESHOLD=0.5
LOG_LEVEL=INFO