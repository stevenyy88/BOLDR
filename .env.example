# BOLDR Self-Improving Customer Intelligence Engine
# Environment Configuration
# Copy this to .env and fill in your values
# Author: Steve Ng, Founder and CEO — Digital Futures Consultancy LLP

# ============================================================
# LLM Configuration
# ============================================================
# Primary: Ollama GLM-5.1 (self-hosted, no API key needed)
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=glm-5.1:cloud

# Fallback: OpenAI-compatible API (optional, for edge cases)
# OPENAI_API_KEY=your_openai_api_key_here
# ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ============================================================
# FastAPI Application
# ============================================================
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO
CONFIDENCE_THRESHOLD=0.5

# ============================================================
# ChromaDB Configuration
# ============================================================
CHROMA_HOST=localhost
CHROMA_PORT=8100
CHROMA_PERSIST_DIR=./chroma_db

# ============================================================
# n8n Configuration
# ============================================================
N8N_HOST=0.0.0.0
N8N_PORT=5678
N8N_PROTOCOL=http
N8N_SECURE_COOKIE=false
GENERIC_TIMEZONE=Asia/Singapore

# ============================================================
# Knowledge Base
# ============================================================
KB_DATA_DIR=./kb
DATA_DIR=./data

# ============================================================
# Streamlit Dashboard
# ============================================================
STREAMLIT_PORT=8501
STREAMLIT_SERVER_HEADLESS=true

# ============================================================
# Note: Zero external credentials required
# All workflows use internal FastAPI HTTP endpoints.
# No Gmail OAuth, no Google Sheets, no WhatsApp Business API keys needed.
# Email intake uses webhook (not Gmail Trigger) — works with any email provider.

# ============================================================
# PII Stripping (GDPR/PDPA Compliance)
# ============================================================
# When enabled, strips emails, phone numbers, NRIC, credit cards
# from messages before they enter the intelligence pipeline.
# Default: false (off for competition demo)
# Set to true for production deployment to comply with PDPA/GDPR.
PII_STRIP_ENABLED=false

# ============================================================
# Channel Integration (Production Webhooks)
# ============================================================
# WhatsApp Business API webhook verification token
# Set this to match your Meta App > Webhooks > Verify Token
WHATSAPP_VERIFY_TOKEN=boldr_verify_2026

# Instagram Graph API webhook verification token
# Set this to match your Meta App > Webhooks > Verify Token
INSTAGRAM_VERIFY_TOKEN=boldr_verify_2026

# IMAP email fetch (optional, for scheduled polling)
# IMAP_HOST=imap.gmail.com
# IMAP_PORT=993
# IMAP_USERNAME=your_email@gmail.com
# IMAP_PASSWORD=your_app_password