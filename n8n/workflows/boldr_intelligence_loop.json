{
  "name": "BOLDR Intelligence Loop",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "boldr-intake",
        "responseMode": "responseNode",
        "options": {}
      },
      "id": "webhook-intake",
      "name": "Multi-Channel Intake Webhook",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2,
      "position": [240, 340],
      "notes": "Receives normalized messages from all intake channels"
    },
    {
      "parameters": {
        "assignments": {
          "assignments": [
            {
              "id": "a1",
              "name": "raw_message",
              "value": "={{ $json.body.message }}",
              "type": "string"
            },
            {
              "id": "a2",
              "name": "channel",
              "value": "={{ $json.body.channel }}",
              "type": "string"
            },
            {
              "id": "a3",
              "name": "sender_id",
              "value": "={{ $json.body.sender_id }}",
              "type": "string"
            },
            {
              "id": "a4",
              "name": "sender_name",
              "value": "={{ $json.body.sender_name }}",
              "type": "string"
            },
            {
              "id": "a5",
              "name": "timestamp",
              "value": "={{ $json.body.timestamp ?? $now.toISO() }}",
              "type": "string"
            },
            {
              "id": "a6",
              "name": "thread_id",
              "value": "={{ $json.body.thread_id }}",
              "type": "string"
            }
          ]
        },
        "options": {}
      },
      "id": "set-normalize",
      "name": "Normalize Intake Data",
      "type": "n8n-nodes-base.set",
      "typeVersion": 3.4,
      "position": [460, 340],
      "notes": "Extract and normalize common fields from any channel"
    },
    {
      "parameters": {
        "method": "POST",
        "url": "http://boldr-app:8000/api/v1/intent",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"message\": \"{{ $json.raw_message }}\",\n  \"channel\": \"{{ $json.channel }}\",\n  \"sender_id\": \"{{ $json.sender_id }}\"\n}",
        "options": {}
      },
      "id": "http-intent",
      "name": "Extract Intent + Persona",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [680, 340],
      "notes": "Calls Python app to classify intent and assign persona"
    },
    {
      "parameters": {
        "assignments": {
          "assignments": [
            {
              "id": "b1",
              "name": "intent",
              "value": "={{ $json.intent }}",
              "type": "string"
            },
            {
              "id": "b2",
              "name": "persona",
              "value": "={{ $json.persona }}",
              "type": "string"
            },
            {
              "id": "b3",
              "name": "confidence",
              "value": "={{ $json.confidence }}",
              "type": "number"
            },
            {
              "id": "b4",
              "name": "sub_intents",
              "value": "={{ $json.sub_intents }}",
              "type": "string"
            }
          ]
        },
        "options": {}
      },
      "id": "set-intent-output",
      "name": "Capture Intent Output",
      "type": "n8n-nodes-base.set",
      "typeVersion": 3.4,
      "position": [900, 340],
      "notes": "Flatten intent extraction response for downstream routing"
    },
    {
      "parameters": {
        "method": "POST",
        "url": "http://boldr-app:8000/api/v1/kb/search",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"query\": \"{{ $json.intent + ' ' + $json.raw_message }}\",\n  \"persona\": \"{{ $json.persona }}\",\n  \"top_k\": 3\n}",
        "options": {}
      },
      "id": "http-kb-search",
      "name": "KB Search (ChromaDB)",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [1120, 340],
      "notes": "Search ChromaDB for matching knowledge entries"
    },
    {
      "parameters": {
        "rules": {
          "rules": [
            {
              "label": "Has Answer",
              "value": "answer_found"
            },
            {
              "label": "Knowledge Gap",
              "value": "knowledge_gap"
            },
            {
              "label": "Shopify Lookup",
              "value": "shopify_lookup"
            },
            {
              "label": "Needs Human",
              "value": "needs_human"
            }
          ]
        },
        "dataPropertyName": "={{ $json.result_type }}"
      },
      "id": "switch-route",
      "name": "Route by Result Type",
      "type": "n8n-nodes-base.switch",
      "typeVersion": 3,
      "position": [1340, 340],
      "notes": "Route based on KB search outcome: answer, gap, Shopify, or human"
    },
    {
      "parameters": {
        "method": "POST",
        "url": "http://boldr-app:8000/api/v1/generate/reply",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"intent\": \"{{ $('Capture Intent Output').item.json.intent }}\",\n  \"persona\": \"{{ $('Capture Intent Output').item.json.persona }}\",\n  \"kb_context\": {{ JSON.stringify($json.documents) }},\n  \"channel\": \"{{ $('Normalize Intake Data').item.json.channel }}\",\n  \"brand_voice\": \"BOLDR\"\n}",
        "options": {}
      },
      "id": "http-draft-reply",
      "name": "Draft BOLDR Reply",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [1600, 200],
      "notes": "Generate reply in BOLDR brand voice using KB context"
    },
    {
      "parameters": {
        "operation": "append",
        "documentId": {
          "__rl": true,
          "value": "",
          "mode": "id"
        },
        "sheetName": {
          "__rl": true,
          "value": "Approval Queue",
          "mode": "name"
        },
        "columns": {
          "mappingMode": "defineBelow",
          "value": {
            "thread_id": "={{ $('Normalize Intake Data').item.json.thread_id }}",
            "channel": "={{ $('Normalize Intake Data').item.json.channel }}",
            "sender_id": "={{ $('Normalize Intake Data').item.json.sender_id }}",
            "sender_name": "={{ $('Normalize Intake Data').item.json.sender_name }}",
            "intent": "={{ $('Capture Intent Output').item.json.intent }}",
            "persona": "={{ $('Capture Intent Output').item.json.persona }}",
            "drafted_reply": "={{ $json.reply }}",
            "confidence": "={{ $('Capture Intent Output').item.json.confidence }}",
            "kb_source": "={{ $json.source_ids }}",
            "status": "pending_approval",
            "created_at": "={{ $now.toISO() }}"
          }
        },
        "options": {}
