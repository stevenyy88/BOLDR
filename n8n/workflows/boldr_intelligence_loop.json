      "type": "n8n-nodes-base.googleSheets",
      "typeVersion": 4.5,
      "position": [1820, 200],
      "notes": "Append drafted reply to Google Sheets approval queue"
    },
    {
      "parameters": {
        "method": "POST",
        "url": "http://boldr-app:8000/api/v1/kb/gap",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Content-Type",
              "value": "application/json"
