            "persona": "={{ $('Capture Intent Output').item.json.persona }}",
            "channel": "={{ $('Normalize Intake Data').item.json.channel }}",
            "status": "open",
            "created_at": "={{ $now.toISO() }}"
          }
        },
        "options": {}
